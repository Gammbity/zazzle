# ------------------------------------------------------------------
# Zazzle frontend environment variables
# Copy this file to `.env` (ignored by git) and fill real values.
# Only VITE_ prefixed variables are exposed to the client bundle.
# ------------------------------------------------------------------

# Base URL of the backend REST API (no trailing slash).
VITE_API_BASE_URL=http://localhost:8000

# Optional: separate uploads/CDN origin. Falls back to VITE_API_BASE_URL if empty.
VITE_UPLOADS_URL=

# Sentry DSN (leave empty to disable error reporting).
VITE_SENTRY_DSN=

# Runtime environment label surfaced in logs/Sentry.
VITE_APP_ENV=development
